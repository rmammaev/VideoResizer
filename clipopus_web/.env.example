# OpusClip API (дашборд → API key, нижний левый угол; план Pro Beta / Business)
OPUS_API_KEY=
OPUS_ORG_ID=

# Публичный адрес сервиса — нужен только чтобы OpusClip слал вебхук о готовности.
# На Railway подставится автоматически из RAILWAY_PUBLIC_DOMAIN; локально можно не задавать
# (тогда работает поллинг). Пример: https://clipopus-web-production.up.railway.app
# PUBLIC_BASE_URL=

# Необязательно: куда складывать файлы (по умолчанию ./data)
# DATA_DIR=data

# Необязательная настройка поллинга
# OPUS_POLL_INTERVAL=15
# OPUS_POLL_TIMEOUT=3600
